{
  "name": "oura-js",
  "version": "1.0.0",
  "description": "A modern, glassmorphic notification library powered by ES6+ and TypeScript",
  "repository": {
    "type": "git",
    "url": "https://github.com/MarkSerna/ourajs.git"
  },
  "homepage": "https://markserna.github.io/ourajs/",
  "bugs": {
    "url": "https://github.com/MarkSerna/ourajs/issues"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/oura.umd.cjs",
  "module": "./dist/oura.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/oura.js",
      "require": "./dist/oura.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs"
  },
  "keywords": [
    "notification",
    "toast",
    "modal",
    "glassmorphism",
    "ui",
    "typescript"
  ],
  "author": "Oura Team",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0",
    "vue": "^3.5.30"
  }
}
